{
    "benchmark_config": {
        "device": "cuda",
        "training_seed": 42,
        "nb_training_seeds": 1,
        "nb_workers": 20,
        "nb_honest_clients": 16,
        "f": 4,
        "tolerated_f": 4,
        "set_honest_clients_as_clients": false,
        "size_train_set": 0.8,
        "data_distribution_seed": 42,
        "nb_data_distribution_seeds": 1,
        "data_distribution": {
            "name": "gamma_similarity_niid",
            "distribution_parameter": 0.66
        },
        "training_algorithm": {
            "name": "DSGD",
            "parameters": {}
        },
        "nb_steps": 500
    },
    "model": {
        "name": "nmnist_snn",
        "is_snn": true,
        "dataset_name": "nmnist",
        "nb_labels": 10,
        "loss": "mse_count_loss",
        "accuracy_name": "accuracy_rate",
        "loss_params": {
            "correct_rate": 0.8,
            "incorrect_rate": 0.2
        },
        "model_params": {
            "beta": 0.95,
            "threshold": 1.0,
            "surrogate_gradient": "atan"
        },
        "encoding": {
            "type": "constant",
            "time_steps": 15,
            "encoding_params": {}
        },
        "learning_rate": 0.02,
        "learning_rate_decay": 1.0,
        "milestones": []
    },
    "aggregator": {
        "name": "GeometricMedian",
        "parameters": {
            "nu": 0.1,
            "T": 3,
            "f": 4
        }
    },
    "pre_aggregators": [
        {
            "name": "NNM",
            "parameters": {
                "f": 4
            }
        },
        {
            "name": "ARC",
            "parameters": {
                "f": 4
            }
        }
    ],
    "honest_clients": {
        "momentum": 0.9,
        "weight_decay": 0.0001,
        "batch_size": 128
    },
    "attack": {
        "name": "Gaussian",
        "parameters": {
            "mu": 0.0,
            "sigma": 1.0
        }
    },
    "evaluation_and_results": {
        "evaluation_delta": 50,
        "batch_size_evaluation": 512,
        "evaluate_on_test": true,
        "store_per_client_metrics": true,
        "store_models": false,
        "data_folder": "./data",
        "results_directory": "./snn_complete_results_nmnist"
    }
}